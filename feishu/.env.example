# Copy this file to .env in the project root or set these variables in your shell.
# Do not commit real secrets.

# Feishu custom bot webhook for the project task group.
FEISHU_WEBHOOK_URL=

# Optional custom bot signing secret. Leave empty if the bot does not enable signature verification.
FEISHU_WEBHOOK_SECRET=

# Feishu app credentials. Required for Tasks API and Bitable API.
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# Bitable identifiers for daily reports and video metrics.
FEISHU_DAILY_REPORT_APP_TOKEN=
FEISHU_DAILY_REPORT_TABLE_ID=
FEISHU_VIDEO_DATA_APP_TOKEN=
FEISHU_VIDEO_DATA_TABLE_ID=

# Optional: task project/list identifiers if using Feishu Task OpenAPI later.
FEISHU_TASKLIST_GUID=
FEISHU_TASKLIST_URL=
FEISHU_TASK_SECTION_GUID=
FEISHU_TASK_OWNER_OPEN_IDS=
FEISHU_TASK_FOLLOWER_OPEN_IDS=
FEISHU_LIN_OPEN_IDS=
FEISHU_DIRECTOR_A_OPEN_IDS=
FEISHU_DIRECTOR_B_OPEN_IDS=

# Feishu group chat id used for inbound market material polling.
# Fill this after running: node scripts/feishu/list-chats.mjs
FEISHU_MARKET_MATERIAL_CHAT_ID=
